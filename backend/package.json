{
  "name": "alsm-backend",
  "version": "1.0.2",
  "description": "Authentik LDAP Sync Management UI - Backend API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js --host --ignore 'data/' --ignore 'logs/'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:syntax": "node --check src/index.js && echo 'Syntax check passed'",
    "test:ci": "vitest run --reporter=verbose && node --check src/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^7.1.0",
    "jose": "^6.2.3",
    "ldap": "^0.7.1",
    "ldapts": "^4.2.6",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.0",
    "socket.io": "^4.6.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "vitest": "^4.1.6"
  }
}
