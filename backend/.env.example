# Server Configuration
PORT=3333
NODE_ENV=production
CORS_ORIGIN=http://localhost:3331

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alsm_ui
DB_USER=postgres
DB_PASSWORD=postgres

# Authentik Configuration
AUTHENTIK_URL=http://localhost:9000
AUTHENTIK_TOKEN=your_api_token_here

# LDAP Configuration
LDAP_HOST=172.17.0.1
LDAP_PORT=389
LDAP_BIND_DN=cn=Directory Manager,dc=spectres,dc=co,dc=za
LDAP_BIND_PASSWORD=your_password_here
LDAP_BASE_DN=dc=spectres,dc=co,dc=za

# Logging
LOG_LEVEL=info

# Sync Configuration
SYNC_INTERVAL_MINUTES=5
SYNC_GROUPS=true
SYNC_DRY_RUN=false
SYNC_CREATE_USERS=true
SYNC_UPDATE_USERS=true
SYNC_DELETE_USERS=false

# LDAP Extended Config
LDAP_USER_BASE_DN=ou=people,dc=spectres,dc=co,dc=za
LDAP_GROUP_BASE_DN=ou=groups,dc=spectres,dc=co,dc=za

# Mailserver Integration
MAILSERVER_ENABLED=false
MAILSERVER_CONTAINER=mailserver
MAILSERVER_DOMAIN=spectres.co.za

# SMTP Configuration (for password emails)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=ALSM
SMTP_FROM_ADDRESS=noreply@example.com
APP_URL=http://localhost:3331
